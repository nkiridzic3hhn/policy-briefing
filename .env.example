# Anthropic API key (server-side proxy)
ANTHROPIC_API_KEY=sk-ant-...

# Login credentials for the dashboard (do NOT commit real values)
AUTH_USER=your-username
AUTH_PASS=your-strong-password

# Secret used to sign session cookies. Set to a long random string in production.
# If omitted, a random one is generated on each restart (logs everyone out on restart).
SESSION_SECRET=change-me-to-a-long-random-string
