# Anthropic API key (server-side proxy)
ANTHROPIC_API_KEY=sk-ant-...

# Login credentials for the dashboard (do NOT commit real values)
AUTH_USER=your-username
AUTH_PASS=your-strong-password

# Secret used to sign session cookies. Set to a long random string in production.
# If omitted, a random one is generated on each restart (logs everyone out on restart).
SESSION_SECRET=change-me-to-a-long-random-string

# ── Newsletter ──
# Postgres connection string. On Railway, reference the Postgres plugin's
# DATABASE_URL. If unset, signups are disabled but the dashboard still works.
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Set to "true" only if connecting to Postgres over the public proxy (needs SSL).
DATABASE_SSL=false

# Resend (email delivery). Get a key at resend.com.
RESEND_API_KEY=re_...
# Verified sending identity (the domain must be verified in Resend).
FROM_EMAIL=Piece of Pi <briefings@pieceofpi.app>

# Public base URL, used for logo + unsubscribe links in emails.
APP_URL=https://www.pieceofpi.app

# How many days back each edition looks for news (default 7).
NEWSLETTER_LOOKBACK_DAYS=7
